        &[::css_lexer::Kind::Ident],
    );
    #[inline(always)]
    fn peek<I>(p: &::css_parse::Parser<'a, I>, c: ::css_parse::Cursor) -> bool
    where
        I: ::std::iter::Iterator<Item = ::css_parse::Cursor> + ::std::clone::Clone,
    {
        use ::css_parse::Peek;
        c == Self::PEEK_KINDSET || <Percentage>::peek(p, c)
